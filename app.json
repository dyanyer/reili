{
  "expo": {
    "name": "Reili",
    "slug": "reili",
    "scheme": "reili",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/reili.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/reili.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1C40"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.dyanyer.reili",
      "adaptiveIcon": {
        "foregroundImage": "./assets/reili.png",
        "backgroundColor": "#0E1C40"
      },
      "edgeToEdgeEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/reili.png",
          "color": "#0E1C40",
          "defaultChannel": "messages"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c86aae22-5523-41ae-8751-a9b7cb8e1372"
      }
    },
    "owner": "dyanyer",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c86aae22-5523-41ae-8751-a9b7cb8e1372"
    }
  }
}
